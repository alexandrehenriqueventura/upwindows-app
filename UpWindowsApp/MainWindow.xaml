<Window x:Class="UpWindowsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UpWindows - Otimizador e Debloater" Height="660" Width="920"
        Background="#121214" Foreground="#FFFFFF" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Estilo padrao dos botoes de acao -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo dos botoes da sidebar -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#2E2E38"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F4F6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1A1A1E" BorderBrush="#25252B" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="75"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="UpWindows" FontSize="22" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center"/>
                    <TextBlock Text="Otimizador de Sistema" FontSize="10" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,15,10,10">
                    <Button x:Name="BtnHome"       Content="Dashboard"              Height="36" Style="{StaticResource SidebarBtn}" Margin="0,4" Click="BtnHome_Click"/>
                    <Button x:Name="BtnTweaks"     Content="Privacidade / IA"       Height="36" Style="{StaticResource SidebarBtn}" Margin="0,4" Click="BtnTweaks_Click"/>
                    <Button x:Name="BtnApps"       Content="Remover Bloatware"      Height="36" Style="{StaticResource SidebarBtn}" Margin="0,4" Click="BtnApps_Click"/>
                    <Button x:Name="BtnUI"         Content="Ajustes de Interface"   Height="36" Style="{StaticResource SidebarBtn}" Margin="0,4" Click="BtnUI_Click"/>
                    <Button x:Name="BtnSystem"     Content="Ajustes de Sistema"     Height="36" Style="{StaticResource SidebarBtn}" Margin="0,4" Click="BtnSystem_Click"/>
                    <Button x:Name="BtnActivation" Content="Ativacao (MAS)"         Height="36" Style="{StaticResource SidebarBtn}" Margin="0,4" Click="BtnActivation_Click"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="Versao 1.1.0" Foreground="#4B5563"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Conteudo principal -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="130"/>
            </Grid.RowDefinitions>

            <TabControl x:Name="MainTabControl" Grid.Row="0"
                        Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <!-- Tab 0: Dashboard -->
                <TabItem Header="Home">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Dashboard Principal" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Cards superiores: Windows Edition / Ativacao / Uptime -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#1A1A1E" Height="90" CornerRadius="6"
                                    BorderBrush="#25252B" BorderThickness="1" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Edicao do Windows" FontSize="11" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtWinEdition" Text="Detectando..." FontSize="13" FontWeight="Bold"
                                               Foreground="#3B82F6" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#1A1A1E" Height="90" CornerRadius="6"
                                    BorderBrush="#25252B" BorderThickness="1" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Status de Ativacao" FontSize="11" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtWinActivation" Text="Detectando..." FontSize="13" FontWeight="Bold"
                                               Foreground="#10B981" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="#1A1A1E" Height="90" CornerRadius="6"
                                    BorderBrush="#25252B" BorderThickness="1" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Tempo de Atividade (Uptime)" FontSize="11" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtUptime" Text="Calculando..." FontSize="13" FontWeight="Bold"
                                               Foreground="#F59E0B" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Colunas principais -->
                        <Grid Grid.Row="2" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Coluna Esquerda -->
                            <StackPanel Grid.Column="0">
                                <!-- Seguranca / Ponto de Restauracao -->
                                <Border Background="#1A1A1E" CornerRadius="6" BorderBrush="#25252B" BorderThickness="1"
                                        Padding="15" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Seguranca do Sistema" FontSize="15" FontWeight="Bold"
                                                   Margin="0,0,0,8" Foreground="#8B5CF6"/>
                                        <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#D1D5DB" FontSize="11" Margin="0,0,0,12"
                                                   Text="Antes de otimizar, crie um Ponto de Restauracao para permitir a reversao do estado do Windows caso ocorra alguma instabilidade."/>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                                            <Button x:Name="BtnCreateRestore" Content="Criar Ponto" Background="#8B5CF6"
                                                    Height="32" FontSize="12" FontWeight="Bold" Padding="10,0" Margin="0,0,8,0"
                                                    Click="BtnCreateRestore_Click"/>
                                            <Button x:Name="BtnExit" Content="Sair" Background="#EF4444"
                                                    Height="32" FontSize="12" FontWeight="Bold" Padding="10,0"
                                                    Click="BtnExit_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Hardware -->
                                <Border Background="#1A1A1E" CornerRadius="6" BorderBrush="#25252B" BorderThickness="1" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="Hardware" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" Foreground="#3B82F6"/>
                                        <TextBlock Text="Processador:" FontWeight="SemiBold" FontSize="11" Foreground="#9CA3AF"/>
                                        <TextBlock x:Name="TxtCpu" Text="Detectando..." FontSize="12" Foreground="#E5E7EB" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                        <TextBlock Text="Placa de Video:" FontWeight="SemiBold" FontSize="11" Foreground="#9CA3AF"/>
                                        <TextBlock x:Name="TxtGpu" Text="Detectando..." FontSize="12" Foreground="#E5E7EB" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                        <TextBlock Text="Memoria RAM:" FontWeight="SemiBold" FontSize="11" Foreground="#9CA3AF"/>
                                        <TextBlock x:Name="TxtRam" Text="Detectando..." FontSize="12" Foreground="#E5E7EB" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Coluna Direita -->
                            <StackPanel Grid.Column="2">
                                <!-- Armazenamento -->
                                <Border Background="#1A1A1E" CornerRadius="6" BorderBrush="#25252B" BorderThickness="1"
                                        Padding="15" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Armazenamento (C:\)" FontSize="15" FontWeight="Bold"
                                                   Margin="0,0,0,10" Foreground="#10B981"/>
                                        <TextBlock x:Name="TxtStorageFree" Text="Livre: Detectando..." FontSize="12" Foreground="#E5E7EB" Margin="0,0,0,5"/>
                                        <ProgressBar x:Name="ProgStorage" Height="8" Minimum="0" Maximum="100" Value="0"
                                                     Background="#2A2A35" Foreground="#10B981" BorderThickness="0" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtStorageTotal" Text="Total: --- GB" FontSize="10"
                                                   Foreground="#6B7280" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>

                                <!-- Acoes Rapidas -->
                                <Border Background="#1A1A1E" CornerRadius="6" BorderBrush="#25252B" BorderThickness="1" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="Acoes Rapidas" FontSize="15" FontWeight="Bold"
                                                   Margin="0,0,0,10" Foreground="#F43F5E"/>
                                        <Button x:Name="BtnCleanTemp"  Content="Limpar Arquivos Temporarios"
                                                Background="#2A2A35" Height="30" FontSize="12" FontWeight="SemiBold"
                                                Margin="0,0,0,6" Click="BtnCleanTemp_Click"/>
                                        <Button x:Name="BtnEmptyTrash" Content="Esvaziar Lixeira"
                                                Background="#2A2A35" Height="30" FontSize="12" FontWeight="SemiBold"
                                                Margin="0,0,0,6" Click="BtnEmptyTrash_Click"/>
                                        <Button x:Name="BtnFlushDNS"   Content="Limpar Cache DNS"
                                                Background="#2A2A35" Height="30" FontSize="12" FontWeight="SemiBold"
                                                Click="BtnFlushDNS_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Tab 1: Privacidade -->
                <TabItem Header="Tweaks">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Privacidade e Telemetria" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Marque os itens que deseja desativar:" FontSize="13" Foreground="#9CA3AF" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkTelemetry"  Content="Desativar Telemetria e Diagnosticos (DiagTrack)"         IsChecked="True"/>
                                <CheckBox x:Name="ChkCEIP"       Content="Desativar CEIP (Customer Experience Improvement Program)" IsChecked="True"/>
                                <CheckBox x:Name="ChkBingSearch" Content="Desativar sugestoes do Bing Search no Menu Iniciar"        IsChecked="True"/>
                                <CheckBox x:Name="ChkCopilot"    Content="Desativar Microsoft Copilot (IA Integrada)"               IsChecked="True"/>
                                <CheckBox x:Name="ChkRecall"     Content="Desativar Windows Recall e rastreadores de IA"            IsChecked="True"/>
                                <CheckBox x:Name="ChkWidgets"    Content="Desativar Painel de Widgets (Noticias e Interesses)"      IsChecked="True"/>
                                <CheckBox x:Name="ChkWindowsAds" Content="Desativar Anuncios Personalizados e Dicas do Windows"     IsChecked="True"/>
                            </StackPanel>
                        </ScrollViewer>
                        <Button Grid.Row="2" x:Name="BtnApplyTweaks" Content="Aplicar Tweaks de Privacidade"
                                Height="38" FontSize="13" FontWeight="Bold" Margin="0,10,0,0"
                                Click="BtnApplyTweaks_Click"/>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Bloatware -->
                <TabItem Header="Bloatware">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Remover Aplicativos Nativos (Bloatware)" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="BtnSelectAll"   Content="Selecionar Todos" Background="#2A2A35" Margin="0,0,8,0" Padding="8,4" Click="BtnSelectAll_Click"/>
                                <Button x:Name="BtnDeselectAll" Content="Desmarcar Todos"  Background="#2A2A35" Padding="8,4"    Click="BtnDeselectAll_Click"/>
                            </StackPanel>
                            <ListBox Grid.Row="1" x:Name="LstApps" Background="#1A1A1E"
                                     BorderBrush="#25252B" BorderThickness="1" Foreground="White"/>
                        </Grid>
                        <Button Grid.Row="2" x:Name="BtnApplyApps" Content="Desinstalar Aplicativos Selecionados"
                                Height="38" FontSize="13" FontWeight="Bold" Margin="0,10,0,0"
                                Click="BtnApplyApps_Click"/>
                    </Grid>
                </TabItem>

                <!-- Tab 3: Interface -->
                <TabItem Header="UI">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Ajustes de Interface e Explorer" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <CheckBox x:Name="ChkClassicMenu"    Content="Restaurar Menu de Contexto Classico (Win10)" IsChecked="False"/>
                                <CheckBox x:Name="ChkTaskbarLeft"    Content="Alinhar Barra de Tarefas a Esquerda"         IsChecked="False"/>
                                <CheckBox x:Name="ChkShowHidden"     Content="Mostrar pastas e arquivos ocultos"            IsChecked="False"/>
                                <CheckBox x:Name="ChkShowExtensions" Content="Mostrar extensoes de arquivos conhecidos"     IsChecked="True"/>
                                <TextBlock Text="* As alteracoes de interface reiniciarao o explorer.exe automaticamente."
                                           FontStyle="Italic" Foreground="#6B7280" FontSize="11" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                        <Button Grid.Row="2" x:Name="BtnApplyUI" Content="Aplicar Tweaks de Interface"
                                Height="38" FontSize="13" FontWeight="Bold" Margin="0,10,0,0"
                                Click="BtnApplyUI_Click"/>
                    </Grid>
                </TabItem>

                <!-- Tab 4: Sistema -->
                <TabItem Header="System">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Ajustes de Sistema" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <CheckBox x:Name="ChkDisableFastStartup" Content="Desativar Fast Startup (recomendado para estabilidade)"               IsChecked="True"/>
                                <CheckBox x:Name="ChkOptimizeDelivery"   Content="Limitar compartilhamento P2P de Updates (Delivery Optimization)" IsChecked="True"/>
                            </StackPanel>
                        </ScrollViewer>
                        <Button Grid.Row="2" x:Name="BtnApplySystem" Content="Aplicar Ajustes de Sistema"
                                Height="38" FontSize="13" FontWeight="Bold" Margin="0,10,0,0"
                                Click="BtnApplySystem_Click"/>
                    </Grid>
                </TabItem>

                <!-- Tab 5: Ativacao -->
                <TabItem Header="Activation">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Ativacao de Licenca (MAS)" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Border Grid.Row="1" Background="#1A1A1E" BorderBrush="#25252B" BorderThickness="1"
                                CornerRadius="6" Padding="15" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Microsoft Activation Scripts (MAS)" FontSize="16" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,0,0,8"/>
                                <TextBlock Text="O MAS e a solucao open-source mais limpa para ativacao de Windows e Office. Uma nova janela de terminal sera aberta para que voce selecione as opcoes interativamente."
                                           TextWrapping="Wrap" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,15"/>
                                <Button x:Name="BtnRunMAS" Content="Iniciar Script de Ativacao MAS"
                                        Background="#8B5CF6" Height="36" FontSize="13" FontWeight="Bold"
                                        HorizontalAlignment="Left" Padding="15,0" Click="BtnRunMAS_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Console de Logs -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Console de Logs (Saida de Processo):" FontSize="11" Foreground="#6B7280"
                           Margin="0,0,0,3" FontWeight="SemiBold"/>
                <TextBox Grid.Row="1" x:Name="TxtLog"
                         Background="#0C0C0F" Foreground="#A7F3D0"
                         BorderBrush="#25252B" BorderThickness="1"
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Padding="6"/>
            </Grid>

            <!-- Toast de Resultado (overlay flutuante) -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="99"
                  VerticalAlignment="Bottom" HorizontalAlignment="Right"
                  Margin="0,0,0,15" IsHitTestVisible="False">
                <Border x:Name="ToastPanel" Padding="16,12" CornerRadius="8"
                        Background="#1A1A26" BorderBrush="#10B981" BorderThickness="1"
                        MinWidth="260" MaxWidth="360" Opacity="0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock x:Name="ToastIcon"  Text="&#x2705;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ToastTitle" Text="Concluido" FontSize="13" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ToastBody"   TextWrapping="Wrap" Foreground="#D1D5DB" FontSize="12"/>
                        <TextBlock x:Name="ToastDetail" TextWrapping="Wrap" Foreground="#6B7280" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
